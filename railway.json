{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "gunicorn --chdir backend --bind 0.0.0.0:$PORT --timeout 120 --workers 1 enhanced_face_api_server:app",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
